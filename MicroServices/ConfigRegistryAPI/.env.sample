APP_NAME=ConfigRegistryAPI
APP_VERSION=1.0.0
ENVIRONMENT=local
SERVICE_NAME=config-registry-api

SQL_SERVER_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost\SQLEXPRESS;DATABASE=genai_db;Trusted_Connection=yes;TrustServerCertificate=yes;
DB_TIMEOUT_SECONDS=30

AUTH_ENABLED=false
JWT_RETURN_CLAIM=sub
JWT_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
JWT_STATIC_PUBLIC_KEY=
JWT_ISSUER=https://issuer.example.com
JWT_AUDIENCE=api://config-registry
JWT_REQUIRED_SCOPES=config:read,config:write
JWT_REQUIRED_ROLES=
JWT_ALLOWED_ALGORITHMS=RS256
JWT_CLOCK_SKEW_SECONDS=60
JWT_REQUIRE_HTTPS_JWKS=true

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/config-registry-api.log
APP_ERROR_FALLBACK_FILE=logs/app-error-fallback.log

KEYVAULT_CONFIG_PATH=
SENSITIVE_RESPONSE_MASK=********

